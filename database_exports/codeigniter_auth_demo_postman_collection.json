{
  "info": {
    "name": "CodeIgniter Auth Demo API",
    "_postman_id": "9d4ee017-7ed6-4304-b6c7-0b6b29f3b001",
    "description": "Collection for register/login JWT flow and protected auth_user + teachers APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "if (json.token) {",
              "  pm.collectionVariables.set('token', json.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "if (json.token) {",
              "  pm.collectionVariables.set('token', json.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Profile (Protected)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "profile"
          ]
        }
      }
    },
    {
      "name": "Teacher - Create User + Teacher (Protected)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ava.stone@example.com\",\n  \"first_name\": \"Ava\",\n  \"last_name\": \"Stone\",\n  \"password\": \"password123\",\n  \"university_name\": \"Stanford University\",\n  \"gender\": \"female\",\n  \"year_joined\": 2022\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/teachers/create-with-user",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "teachers",
            "create-with-user"
          ]
        }
      }
    },
    {
      "name": "Data - auth_user Table (Protected)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth-users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth-users"
          ]
        }
      }
    },
    {
      "name": "Data - teachers Table (Protected)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/teachers",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "teachers"
          ]
        }
      }
    },
    {
      "name": "Data - teachers with users (Protected)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/teachers-with-users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "teachers-with-users"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}
